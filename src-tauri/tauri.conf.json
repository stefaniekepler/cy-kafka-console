{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kafka Console",
  "version": "0.1.0",
  "identifier": "com.cy.kafkaconsole",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": { "../resources/jre": "jre", "../resources/kafbat": "kafbat" },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/stefaniekepler/cy-kafka-console/releases/latest/download/latest.json"],
